# Backend API base URL
# Dev: "/api" (Vite proxy forwards to http://localhost:5000)
# Prod: full URL e.g. https://api.example.com/api
VITE_API_URL=/api

# Origin where backend serves /uploads (no trailing slash)
# Dev: leave empty (Vite proxy forwards /uploads to backend)
# Prod: full origin e.g. https://api.example.com
VITE_UPLOADS_URL=
